# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourAppName

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin Password (for createAdmin script)
ADMIN_PASSWORD=your_secure_admin_password_at_least_8_characters

# Admin notifications (comma-separated)
ADMIN_NOTIFICATIONS_EMAIL=admin@ruvia.com,support@ruvia.com

# Payment Gateway - Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email Configuration (Mailtrap for development, SMTP for production)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_pass
EMAIL_ENABLED=true
EMAIL_FROM_NAME=Ruvia
EMAIL_FROM_EMAIL=noreply@ruvia.com
EMAIL_REPLY_TO=support@ruvia.com
EMAIL_BRAND_NAME=Ruvia Cosmetics
EMAIL_SUPPORT_EMAIL=support@ruvia.com

# Frontend URL used in email buttons/links
FRONTEND_URL=http://localhost:3000

# Cloudinary - Image Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
